{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "types": ["jest", "@testing-library/jest-dom"],
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
      "@9nau/ui": ["../../packages/nau-ui/src/index.ts"],
      "@9nau/ui/*": ["../../packages/nau-ui/src/*"],
      "@9nau/core": ["../../packages/nau-core/src/index.ts"],
      "@9nau/core/*": ["../../packages/nau-core/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "cypress"],
  "references": [
    {
      "path": "../../packages/types"
    },
    {
      "path": "../../packages/ui"
    }
  ]
}
