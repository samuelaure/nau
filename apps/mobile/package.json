{
  "name": "mobile",
  "version": "1.1.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --fix --cache",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "clean": "expo-cli cache:clear && rimraf node_modules",
    "build:local": "npm run prebuild && cd android && gradlew assembleRelease",
    "build:preview": "eas build -p android --profile preview"
  },
  "dependencies": {
    "@react-native-community/datetimepicker": "7.7.0",
    "expo": "~50.0.6",
    "expo-av": "~13.10.6",
    "expo-clipboard": "~5.0.1",
    "expo-file-system": "~16.0.9",
    "expo-linking": "~6.2.2",
    "expo-share-intent": "^1.9.0",
    "expo-sharing": "~11.10.0",
    "expo-splash-screen": "~0.26.4",
    "expo-sqlite": "~13.4.0",
    "expo-status-bar": "~1.11.1",
    "expo-system-ui": "~2.9.4",
    "expo-video-thumbnails": "~7.9.0",
    "lucide-react-native": "^0.322.0",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-reanimated": "~3.6.2",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-svg": "14.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.45",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-native": "^4.1.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "private": true
}
