# --- Core ---
NODE_ENV=production
LOG_LEVEL=info

# --- Database ---
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=whatsnau

# --- Redis ---
REDIS_PASSWORD=

# --- Auth ---
AUTH_SECRET=
JWT_EXPIRES_IN=7d

# --- CORS ---
ALLOWED_ORIGINS=https://whatsnau.9nau.com

# --- Dashboard ---
DASHBOARD_URL=https://whatsnau.9nau.com

# --- Initial admin (first-boot only, remove after setup) ---
INITIAL_ADMIN_PASSWORD=

# --- Telegram (system notifications) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_SYSTEM_CHAT_ID=

# --- Meta App (Embedded Signup) ---
META_APP_ID=
META_APP_SECRET=

# --- WhatsApp ---
WHATSAPP_PROVIDER=meta
WHATSAPP_VERSION=v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_PHONE_NUMBER=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# --- YCloud (alternative provider) ---
YCLOUD_API_KEY=

# --- AI ---
OPENAI_API_KEY=
PRIMARY_AI_MODEL=gpt-4o
CHEAP_AI_MODEL=gpt-4o-mini
