# --- Core ---
NODE_ENV=production
LOG_LEVEL=info

# --- Database ---
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=flownau

# --- Redis ---
REDIS_PASSWORD=

# --- Auth ---
# Shared HS256 secret — must be identical across all platform services
AUTH_SECRET=
NEXTAUTH_URL=https://flownau.9nau.com

# --- Public URLs (baked into Next.js bundle at build time) ---
NEXT_PUBLIC_ACCOUNTS_URL=https://accounts.9nau.com
NEXT_PUBLIC_APP_URL=https://app.9nau.com

# --- Internal service URLs (Docker network) ---
NAU_API_URL=http://api:3000
NAUTHENTICITY_URL=http://nauthenticity:3000
ZAZU_INTERNAL_URL=http://zazu-bot:3000

# --- Cron protection ---
CRON_SECRET=

# --- AI (LLM abstraction layer) ---
# LLM_PROVIDER controls which provider createDefaultLLMClient() uses (default: openai)
# LLM_API_KEY overrides the provider-specific key below
LLM_PROVIDER=openai
# LLM_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# --- Storage (Cloudflare R2) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=nau-storage
R2_PUBLIC_URL=

# --- Meta (Facebook Login) ---
FB_APP_ID=
FB_APP_SECRET=

# --- Misc ---
RENDER_CONCURRENCY=1
