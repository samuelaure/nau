generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String          @id @default(cuid())
  name      String?
  email     String?         @unique
  password  String?
  image     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  workspaces WorkspaceUser[]
}

model Workspace {
  id        String          @id @default(cuid())
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  
  users     WorkspaceUser[]
  accounts  SocialAccount[]
}

model WorkspaceUser {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        String    @default("owner") // owner, admin, member
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model SocialAccount {
  id           String        @id @default(cuid())
  workspaceId  String
  platform     String        @default("instagram")
  platformId   String?
  username     String?
  profileImage String?
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  directorPrompt String?     @db.Text // ONE: Selection logic for idea-template fit
  creationPrompt String?     @db.Text // NEW: Native iteration instructions for template building
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  shortCode    String?
  assetsRoot   String?
  tokenExpiresAt   DateTime?   // v2: Track IG token expiry (60-day lifecycle)
  tokenRefreshedAt DateTime?   // v2: Last token refresh timestamp
  assets          Asset[]
  compositions    Composition[]
  brandPersonas   BrandPersona[]
  contentIdeas    ContentIdea[]
  ideasFrameworks IdeasFramework[]
  postingSchedule PostingSchedule?
  contentPlans    ContentPlan[]
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  templates       Template[]

  @@unique([platform, platformId])
}

model Asset {
  id               String         @id @default(cuid())
  accountId        String?
  templateId       String?
  type             String
  systemFilename   String
  originalFilename String
  r2Key            String
  url              String
  size             Int
  mimeType         String
  hash             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  thumbnailUrl     String?
  duration         Float?
  description      String?        @db.Text
  tags             String[]       @default([])    // v2: Content tags for AI asset matching
  lastUsedAt       DateTime?                      // v2: Last time this asset was used in a composition
  usageCount       Int            @default(0)     // v2: Number of times used (for diversity scoring)
  account          SocialAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  template         Template?      @relation(fields: [templateId], references: [id])
}

model Template {
  id               String         @id @default(cuid())
  name             String
  remotionId       String

  config           Json?
  accountId        String?
  useAccountAssets Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  assetsRoot       String?
  systemPrompt     String?        @db.Text // TEMPLATE SPECIFIC: Narrative multiplier
  creationPrompt   String?        @db.Text // Specific iteration logic for this template
  captionPrompt    String?        @db.Text // Specific logic for generating captions
  schemaJson       Json?          // Structural schema for reference
  // v2: Scene blueprint fields (Phase 2 will use these)
  sceneType        String?        // Maps to a VideoSceneType or ImageSceneType
  slotSchema       Json?          // Typed slot definitions for this scene blueprint
  styleConfig      Json?          // Visual style overrides
  renders          Render[]        // DEPRECATED (v2): Use RenderJob instead. Kept for backward compat.
  assets           Asset[]
  compositions     Composition[]
  account          SocialAccount? @relation(fields: [accountId], references: [id])
}

/// DEPRECATED: Legacy render tracking. Will be removed in Phase 3 when RenderJob fully replaces it.
/// Do NOT use for new code — use RenderJob instead.
model Render {
  id               String   @id @default(cuid())
  templateId       String
  status           String   @default("IDLE")
  progress         Float    @default(0)
  inputData        Json?
  r2Url            String?
  instagramMediaId String?
  instagramStatus  String?
  error            String?
  renderLog        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  template         Template @relation(fields: [templateId], references: [id])
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AIModel {
  GROQ_LLAMA_3_3
  GROQ_LLAMA_3_1_70B
  GROQ_LLAMA_3_1_8B
  GROQ_MIXTRAL_8X7B
  GROQ_DEEPSEEK_R1_70B
  OPENAI_GPT_4O
  OPENAI_GPT_4O_MINI
  OPENAI_GPT_4_TURBO
  OPENAI_GPT_4_1
  OPENAI_O1
  OPENAI_O1_MINI
}

model BrandPersona {
  id                      String   @id @default(cuid())
  accountId               String
  name                    String   // e.g. "Sassy Educator", "Formal B2B"
  systemPrompt            String   @db.Text // Tone, Voice, Personality
  modelSelection          AIModel  @default(GROQ_LLAMA_3_3)
  isDefault               Boolean  @default(false)
  autoApproveIdeas        Boolean  @default(false)
  autoApproveCompositions Boolean  @default(false)

  // Per-origin engine settings (Phase 8)
  capturedAutoApprove     Boolean  @default(true)   // Captured ideas auto-approved (from 9naŭ)
  capturedCount           Int      @default(3)       // Ideas spawned per captured concept
  manualAutoApprove       Boolean  @default(true)    // Manual ideas auto-approved (operator input)
  manualCount             Int      @default(5)       // Ideas spawned per manual brainstorm session
  automaticAutoApprove    Boolean  @default(false)   // Automatic ideas require review
  automaticCount          Int      @default(5)       // Ideas generated per cron cycle

  account                 SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model IdeasFramework {
  id                      String   @id @default(cuid())
  accountId               String
  name                    String   // e.g. "Viral Hook Framework", "Educational Series"
  systemPrompt            String   @db.Text // Used ONLY for generating ideas list
  isDefault               Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  account                 SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model ContentIdea {
  id           String        @id @default(cuid())
  accountId    String
  ideaText     String        @db.Text
  status       String        @default("PENDING") // PENDING, APPROVED, REJECTED, USED
  source       String        @default("automatic") // automatic | manual | captured
  sourceRef    String?                             // External reference ID
  priority     Int           @default(3)           // 1: captured, 2: manual, 3: automatic
  createdAt    DateTime      @default(now())
  compositions Composition[]                       // Back-reference to compositions created from this idea
  account      SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Composition {
  id               String        @id @default(cuid())
  accountId        String
  templateId       String?                          // v2: Now optional — scene-based compositions don't require a template
  format           String        @default("reel")   // v2: reel | trial_reel | carousel | single_image
  creative         Json?                            // v2: AI CreativeDirection output (scene sequence + slots)
  payload          Json                             // The compiled composition schema (DynamicCompositionSchema)
  videoUrl         String?
  coverUrl         String?                          // v2: Cover image URL for reel thumbnails
  caption          String?       @db.Text
  hashtags         String[]      @default([])       // v2: Generated hashtags
  externalPostId   String?
  externalPostUrl  String?
  status           String        @default("DRAFT")  // DRAFT, APPROVED, RENDERING, RENDERED, SCHEDULED, PUBLISHING, PUBLISHED, FAILED
  scheduledAt      DateTime?
  publishAttempts  Int           @default(0)
  lastPublishError String?      @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  ideaId           String?                          // v2: Back-reference to the source idea
  sceneTypes       String[]      @default([])       // v2: Scene types used (for diversity tracking)
  topicHash        String?                          // v2: Hash of main topic (for dedup)
  
  account          SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  template         Template?     @relation(fields: [templateId], references: [id])
  idea             ContentIdea?  @relation(fields: [ideaId], references: [id])
  renderJob        RenderJob?                       // v2: Async render job
}

/// v2: Async render job queue — tracks render status for compositions
model RenderJob {
  id            String      @id @default(cuid())
  compositionId String      @unique
  status        String      @default("queued")    // queued | rendering | uploading | done | failed
  progress      Float       @default(0)
  outputUrl     String?                           // R2 URL of rendered output
  outputType    String      @default("video")     // video | image | images
  error         String?     @db.Text
  attempts      Int         @default(0)
  maxAttempts   Int         @default(3)
  startedAt     DateTime?
  completedAt   DateTime?
  renderTimeMs  Int?                              // Performance tracking
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  composition   Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
}

/// v2: Daily content plan — tracks what content is planned for each day per account
model ContentPlan {
  id          String        @id @default(cuid())
  accountId   String
  date        DateTime      @db.Date             // Calendar date (no time component)
  pieces      Json                               // Array of planned content piece summaries
  scripts     Json?                              // Pending head-talk recording scripts
  delivered   Boolean       @default(false)      // Whether plan was delivered via Zazŭ
  deliveredAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  account     SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
}

model PostingSchedule {
  id            String        @id @default(cuid())
  accountId     String        @unique
  frequencyDays Int           @default(1) // E.g., post every X days
  reelsPerDay   Int           @default(5)          // v2: Target reels per day
  trialReelsPerDay Int        @default(5)          // v2: Target trial reels per day
  postingTimes  Json          @default("[]")       // v2: Array of HH:MM strings for posting
  trialPostingTimes Json     @default("[]")       // v2: Separate times for trial reels
  timezone      String        @default("Europe/Madrid") // v2: Account timezone
  lastPostedAt  DateTime?
  
  account       SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}
