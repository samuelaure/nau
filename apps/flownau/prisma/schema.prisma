generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ── Brand ──────────────────────────────────────────────────────────────────────
// Local flownau mirror of the 9naŭ Brand.  id = 9naŭ Brand.id.
// Stores flownau-specific pipeline config (prompts, short code, assets root).
// Content pipeline (ideas, compositions, plans, templates, assets) is anchored here.
model Brand {
  id             String   @id            // = 9naŭ Brand.id
  workspaceId    String                  // = 9naŭ Workspace.id
  name           String?                 // cached from 9naŭ API
  shortCode      String?
  assetsRoot     String?
  language             String   @default("Spanish")
  ideationCount        Int      @default(9)
  autoApproveIdeas     Boolean  @default(false)
  coverageHorizonDays  Int      @default(7)
  ideationPrompt       String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  socialProfiles       SocialProfile[]
  assets               Asset[]
  templates            Template[]
  brandTemplateConfigs BrandTemplateConfig[]
  posts                Post[]
  contentPlans         ContentPlan[]
  postSchedule         PostSchedule?
  postSlots            PostSlot[]
}

// ── PostSchedule ───────────────────────────────────────────────────────────────
// One per brand. Defines the repeating format chain + daily posting rhythm.
model PostSchedule {
  id             String   @id @default(cuid())
  brandId        String   @unique
  brand          Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  formatChain    String[]             // ordered format list, repeats cyclically
  chainPosition  Int      @default(0) // current position in formatChain
  dailyFrequency Int      @default(1) // posts per day
  windowStart    String   @default("09:00") // "HH:MM" in brand timezone
  windowEnd      String   @default("21:00") // "HH:MM" in brand timezone
  timezone       String   @default("UTC")
  isActive       Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ── PostSlot ───────────────────────────────────────────────────────────────────
// A materialized calendar entry. Created by the slot materialization service.
// Filled when an IDEA_APPROVED post is auto-composed into it.
model PostSlot {
  id          String    @id @default(cuid())
  brandId     String
  brand       Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)

  scheduledAt DateTime               // exact UTC datetime for this slot
  format      String                 // format assigned by chain position
  status      String  @default("empty") // empty | filled | published

  postId      String?  @unique       // null until filled
  post        Post?    @relation(fields: [postId], references: [id])

  createdAt   DateTime @default(now())

  @@index([brandId, scheduledAt])
  @@index([brandId, status])
}

// ── SocialProfile ──────────────────────────────────────────────────────────────
// A posting channel — the endpoint of the brand's content pipeline.
// One brand can have many social profiles (Instagram today, more platforms soon).
model SocialProfile {
  id               String    @id @default(cuid())
  brandId          String
  brand            Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  workspaceId      String
  platform         String    @default("instagram")
  platformId       String?
  username         String?
  profileImage     String?
  accessToken      String?   // Optional for soft-added profiles awaiting OAuth
  refreshToken     String?
  expiresAt        DateTime?
  tokenExpiresAt   DateTime?
  tokenRefreshedAt DateTime?

  // Track if this profile was synced from nauthenticity
  syncedFromNauthenticity Boolean @default(false)
  nauthenticityProfileId  String? // Reference to nauthenticity SocialProfile.id if synced

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([platform, platformId])
}

model Asset {
  id               String    @id @default(cuid())
  brandId          String?
  templateId       String?
  type             String
  systemFilename   String
  originalFilename String
  r2Key            String
  url              String
  size             Int
  mimeType         String
  hash             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  thumbnailUrl     String?
  duration         Float?
  description      String?   @db.Text
  tags             String[]  @default([])
  lastUsedAt       DateTime?
  usageCount       Int       @default(0)

  brand    Brand?    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  template Template? @relation(fields: [templateId], references: [id])
}

model Template {
  id               String    @id @default(cuid())
  name             String
  format           String    @default("reel")   // reel | head_talk | carousel | static_post
  remotionId       String    @default("")
  config           Json?
  brandId          String?               // null for system-scoped templates
  scope            String    @default("system")  // system | brand
  useBrandAssets   Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  assetsRoot       String?
  systemPrompt     String?   @db.Text
  creationPrompt   String?   @db.Text
  captionPrompt    String?   @db.Text
  schemaJson       Json?
  contentSchema    Json?
  sceneType        String?
  slotSchema       Json?
  styleConfig      Json?

  renders      Render[]
  assets       Asset[]
  posts        Post[]
  brandConfigs BrandTemplateConfig[]
  brand        Brand?  @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

model BrandTemplateConfig {
  id               String   @id @default(cuid())
  brandId          String
  templateId       String
  autoApproveDraft Boolean  @default(false)
  autoApprovePost  Boolean  @default(false)  // autoApproveRendered — kept as autoApprovePost
  enabled          Boolean  @default(true)
  customPrompt     String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([brandId, templateId])
}

/// DEPRECATED: Legacy render tracking. Use RenderJob instead.
model Render {
  id               String   @id @default(cuid())
  templateId       String
  status           String   @default("IDLE")
  progress         Float    @default(0)
  inputData        Json?
  r2Url            String?
  instagramMediaId String?
  instagramStatus  String?
  error            String?
  renderLog        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  template         Template @relation(fields: [templateId], references: [id])
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AIModel {
  GROQ_LLAMA_3_3
  GROQ_LLAMA_3_1_70B
  GROQ_LLAMA_3_1_8B
  GROQ_MIXTRAL_8X7B
  GROQ_DEEPSEEK_R1_70B
  OPENAI_GPT_4O
  OPENAI_GPT_4O_MINI
  OPENAI_GPT_4_TURBO
  OPENAI_GPT_4_1
  OPENAI_O1
  OPENAI_O1_MINI
}

model BrandPersona {
  id                      String   @id @default(cuid())
  brandId                 String   // 9naŭ Brand.id
  workspaceId             String   // 9naŭ Workspace.id
  name                    String
  systemPrompt            String   @db.Text
  modelSelection          AIModel  @default(GROQ_LLAMA_3_3)
  isDefault               Boolean  @default(false)
  autoApproveIdeas        Boolean  @default(false)
  autoApproveCompositions Boolean  @default(false)
  autoApprovePool         Boolean  @default(false)
  capturedAutoApprove     Boolean  @default(false)
  capturedCount           Int      @default(3)
  manualAutoApprove       Boolean  @default(false)
  manualCount             Int      @default(5)
  automaticAutoApprove    Boolean  @default(false)
  automaticCount          Int      @default(5)

  posts        Post[]
}

model IdeasFramework {
  id           String   @id @default(cuid())
  brandId      String   // 9naŭ Brand.id
  workspaceId  String   // 9naŭ Workspace.id
  name         String
  systemPrompt String   @db.Text
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContentCreationPrinciples {
  id           String   @id @default(cuid())
  brandId      String   // 9naŭ Brand.id
  workspaceId  String   // 9naŭ Workspace.id
  name         String
  systemPrompt String   @db.Text
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Post ───────────────────────────────────────────────────────────────────────
// Single evolving entity for the entire content pipeline.
// Starts as an idea (IDEA_PENDING) and progresses through draft, scheduling,
// rendering, and publishing — accumulating data at each stage.
//
// Status machine:
//   IDEA_PENDING → IDEA_APPROVED → DRAFT_PENDING → DRAFT_APPROVED
//   → SCHEDULED → RENDERING → RENDERED_PENDING → RENDERED_APPROVED → PUBLISHED
model Post {
  id        String @id @default(cuid())
  brandId   String

  // Combined stage + review status
  status    String @default("IDEA_PENDING")
  // IDEA_PENDING | IDEA_APPROVED | DRAFT_PENDING | DRAFT_APPROVED
  // | SCHEDULED | RENDERING | RENDERED_PENDING | RENDERED_APPROVED | PUBLISHED

  // ── Stage 1: Idea ──────────────────────────────────────────────────────────
  ideaText          String    @db.Text
  language          String?
  source            String    @default("manual")   // manual | capture | automatic
  sourceRef         String?                         // digest URLs, inspo lineage
  priority          Int       @default(3)           // 1=capture, 2=manual, 3=automatic
  generationBatchId String?                         // groups ideas from the same ideation request

  // ── Stage 2: Draft (set when IDEA_APPROVED → DRAFT_PENDING) ───────────────
  templateId           String?
  format               String?                      // set at draft creation from template
  creative             Json?                        // format-agnostic scene/script/slide data
  payload              Json?                        // compiled rendering timeline
  caption              String?   @db.Text
  hashtags             String[]  @default([])
  sceneTypes           String[]  @default([])
  topicHash            String?
  userUploadedMediaUrl String?
  brandPersonaId       String?                      // persona used by the composer

  // ── Stage 3: Scheduling ────────────────────────────────────────────────────
  scheduledAt          DateTime?

  // ── Stage 4: Publishing ────────────────────────────────────────────────────
  videoUrl           String?
  coverUrl           String?
  externalPostId     String?
  externalPostUrl    String?
  publishAttempts    Int       @default(0)
  lastPublishError   String?   @db.Text
  userPostedManually Boolean   @default(false)
  publishedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand         Brand         @relation(fields: [brandId], references: [id], onDelete: Cascade)
  template      Template?     @relation(fields: [templateId], references: [id])
  brandPersona  BrandPersona? @relation(fields: [brandPersonaId], references: [id])
  renderJob     RenderJob?
  postSlot      PostSlot?

  @@index([brandId, status])
  @@index([generationBatchId])
  @@index([scheduledAt])
}

model RenderJob {
  id        String @id @default(cuid())
  postId    String @unique
  status    String @default("queued")
  progress  Float  @default(0)
  outputUrl String?
  outputType String @default("video")
  error     String? @db.Text
  attempts  Int     @default(0)
  maxAttempts Int   @default(3)
  startedAt   DateTime?
  completedAt DateTime?
  renderTimeMs Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model ContentPlan {
  id          String   @id @default(cuid())
  brandId     String
  date        DateTime @db.Date
  pieces      Json
  scripts     Json?
  delivered   Boolean  @default(false)
  deliveredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, date])
}

model ContentPlanner {
  id                  String   @id @default(cuid())
  brandId             String   // 9naŭ Brand.id
  workspaceId         String   // 9naŭ Workspace.id
  name                String
  isDefault           Boolean  @default(false)
  autoApproveSchedule Boolean  @default(false)
  strategistPrompt    String?  @db.Text
  daysToPlan          Int      @default(7)
  frequencyDays       Int      @default(1)
  reelsPerDay         Int      @default(5)
  trialReelsPerDay    Int      @default(5)
  postingTimes        Json     @default("[]")
  trialPostingTimes   Json     @default("[]")
  timezone            String   @default("Europe/Madrid")
  lastPostedAt        DateTime?

  @@unique([brandId, name])
}
