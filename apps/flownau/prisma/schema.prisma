generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id                   String          @id @default(cuid())
  name                 String
  platformWorkspaceId  String?         // 9naŭ Workspace.id reference
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  users     WorkspaceUser[]
  accounts  SocialAccount[]
}

model WorkspaceUser {
  id               String    @id @default(cuid())
  platformUserId   String    // 9naŭ User.id (replaces local userId)
  workspaceId      String
  role             String    @default("owner")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([platformUserId, workspaceId])
}

model SocialAccount {
  id           String        @id @default(cuid())
  workspaceId  String
  platform     String        @default("instagram")
  platformId   String?
  username     String?
  profileImage String?
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  brandId        String?               // nauthenticity Brand.id reference
  directorPrompt String?     @db.Text
  creationPrompt String?     @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  shortCode    String?
  assetsRoot   String?
  tokenExpiresAt   DateTime?   // v2: Track IG token expiry (60-day lifecycle)
  tokenRefreshedAt DateTime?   // v2: Last token refresh timestamp
  assets                  Asset[]
  compositions            Composition[]
  brandPersonas           BrandPersona[]
  contentIdeas            ContentIdea[]
  ideasFrameworks         IdeasFramework[]
  contentPrinciples       ContentCreationPrinciples[]
  contentPlanners         ContentPlanner[]
  contentPlans            ContentPlan[]
  accountTemplateConfigs  AccountTemplateConfig[]
  workspace               Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  templates               Template[]

  @@unique([platform, platformId])
}

model Asset {
  id               String         @id @default(cuid())
  accountId        String?
  templateId       String?
  type             String
  systemFilename   String
  originalFilename String
  r2Key            String
  url              String
  size             Int
  mimeType         String
  hash             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  thumbnailUrl     String?
  duration         Float?
  description      String?        @db.Text
  tags             String[]       @default([])    // v2: Content tags for AI asset matching
  lastUsedAt       DateTime?                      // v2: Last time this asset was used in a composition
  usageCount       Int            @default(0)     // v2: Number of times used (for diversity scoring)
  account          SocialAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  template         Template?      @relation(fields: [templateId], references: [id])
}

model Template {
  id               String         @id @default(cuid())
  name             String
  remotionId       String

  config           Json?
  accountId        String                           // Phase 18: required; templates are account-scoped
  scope            String         @default("account") // account | workspace — workspace = visible to sibling accounts
  useAccountAssets Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  assetsRoot       String?
  systemPrompt     String?        @db.Text // TEMPLATE SPECIFIC: Narrative multiplier
  creationPrompt   String?        @db.Text // Specific iteration logic for this template
  captionPrompt    String?        @db.Text // Specific logic for generating captions
  schemaJson       Json?          // Structural schema for reference (visual structure)
  contentSchema    Json?          // Phase 18: text-slot specs fed to composer AI (text count/length/intent/caption specs)
  // v2: Scene blueprint fields
  sceneType        String?        // Maps to a VideoSceneType or ImageSceneType
  slotSchema       Json?          // Typed slot definitions for this scene blueprint
  styleConfig      Json?          // Visual style overrides
  renders          Render[]        // DEPRECATED (v2): Use RenderJob instead. Kept for backward compat.
  assets           Asset[]
  compositions     Composition[]
  accountConfigs   AccountTemplateConfig[]
  account          SocialAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

/// Phase 18: per-account settings for Templates (required so workspace-shared templates
/// can be gated and toggled independently per account).
model AccountTemplateConfig {
  id              String   @id @default(cuid())
  accountId       String
  templateId      String
  autoApprovePost Boolean  @default(false)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account         SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  template        Template      @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([accountId, templateId])
}

/// DEPRECATED: Legacy render tracking. Will be removed in Phase 3 when RenderJob fully replaces it.
/// Do NOT use for new code — use RenderJob instead.
model Render {
  id               String   @id @default(cuid())
  templateId       String
  status           String   @default("IDLE")
  progress         Float    @default(0)
  inputData        Json?
  r2Url            String?
  instagramMediaId String?
  instagramStatus  String?
  error            String?
  renderLog        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  template         Template @relation(fields: [templateId], references: [id])
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AIModel {
  GROQ_LLAMA_3_3
  GROQ_LLAMA_3_1_70B
  GROQ_LLAMA_3_1_8B
  GROQ_MIXTRAL_8X7B
  GROQ_DEEPSEEK_R1_70B
  OPENAI_GPT_4O
  OPENAI_GPT_4O_MINI
  OPENAI_GPT_4_TURBO
  OPENAI_GPT_4_1
  OPENAI_O1
  OPENAI_O1_MINI
}

model BrandPersona {
  id                      String   @id @default(cuid())
  accountId               String
  name                    String   // e.g. "Sassy Educator", "Formal B2B"
  systemPrompt            String   @db.Text // Tone, Voice, Personality
  modelSelection          AIModel  @default(GROQ_LLAMA_3_3)
  isDefault               Boolean  @default(false)
  autoApproveIdeas        Boolean  @default(false) // Gate: Ideation (PENDING → APPROVED)
  autoApproveCompositions Boolean  @default(false) // Gate: legacy compositions auto-advance
  autoApprovePool         Boolean  @default(false) // Gate: Content Pool (DRAFT → APPROVED)

  // Per-origin engine settings
  capturedAutoApprove     Boolean  @default(false)
  capturedCount           Int      @default(3)
  manualAutoApprove       Boolean  @default(false)
  manualCount             Int      @default(5)
  automaticAutoApprove    Boolean  @default(false)
  automaticCount          Int      @default(5)

  account                 SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ideas                   ContentIdea[]
  compositions            Composition[]
}

model IdeasFramework {
  id                      String   @id @default(cuid())
  accountId               String
  name                    String   // e.g. "Viral Hook Framework", "Educational Series"
  systemPrompt            String   @db.Text // Used ONLY for generating ideas list
  isDefault               Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  account                 SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ideas                   ContentIdea[]
  compositions            Composition[]
}

/// Phase 18: creative best-practices / engagement principles used by the composer AI
/// during Content Development. Shaped like IdeasFramework but scoped to content creation.
model ContentCreationPrinciples {
  id           String   @id @default(cuid())
  accountId    String
  name         String
  systemPrompt String   @db.Text
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account      SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ideas        ContentIdea[]
  compositions Composition[]
}

model ContentIdea {
  id                   String        @id @default(cuid())
  accountId            String
  ideaText             String        @db.Text
  format               String?                             // reel | trial_reel | head_talk | carousel | static_post | story
  status               String        @default("PENDING") // PENDING, APPROVED, REJECTED, USED
  source               String        @default("automatic") // automatic | manual | captured
  sourceRef            String?                             // External reference ID
  priority             Int           @default(3)           // 1: captured, 2: manual, 3: automatic
  aiLinked             Boolean       @default(false)       // true = routed by AI brand detection; requires human review
  createdAt            DateTime      @default(now())

  // Phase 18: provenance — remembered from generation so content dev honours the same voice/strategy
  brandPersonaId       String?
  ideasFrameworkId     String?
  contentPrinciplesId  String?

  compositions         Composition[]                       // Back-reference to compositions created from this idea
  account              SocialAccount             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  brandPersona         BrandPersona?             @relation(fields: [brandPersonaId], references: [id])
  ideasFramework       IdeasFramework?           @relation(fields: [ideasFrameworkId], references: [id])
  contentPrinciples    ContentCreationPrinciples? @relation(fields: [contentPrinciplesId], references: [id])
}

model Composition {
  id                   String        @id @default(cuid())
  accountId            String
  templateId           String?                          // nullable only for `replicate` format; everything else must link
  format               String        @default("reel")   // reel | trial_reel | carousel | single_image | head_talk | replicate
  creative             Json?                            // v2: AI CreativeDirection output (scene sequence + slots)
  payload              Json                             // The compiled composition schema (DynamicCompositionSchema)
  videoUrl             String?
  coverUrl             String?                          // v2: Cover image URL for reel thumbnails
  caption              String?       @db.Text
  hashtags             String[]      @default([])       // v2: Generated hashtags
  externalPostId       String?
  externalPostUrl      String?
  source               String        @default("composed") // composed | replicate
  status               String        @default("DRAFT")  // DRAFT, APPROVED, RENDERING, RENDERED, SCHEDULED, PUBLISHING, PUBLISHED, FAILED
  scheduledAt          DateTime?
  publishAttempts      Int           @default(0)
  lastPublishError     String?       @db.Text
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  ideaId               String?                          // Back-reference to the source idea
  sceneTypes           String[]      @default([])       // Scene types used (for diversity tracking)
  topicHash            String?                          // Hash of main topic (for dedup)

  // Phase 18: provenance (copied from idea at creation for audit & re-runs)
  brandPersonaId       String?
  ideasFrameworkId     String?
  contentPrinciplesId  String?

  // Phase 18: user-managed media (head_talk / replicate formats)
  userUploadedMediaUrl String?
  userPostedManually   Boolean       @default(false)

  account              SocialAccount             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  template             Template?                 @relation(fields: [templateId], references: [id])
  idea                 ContentIdea?              @relation(fields: [ideaId], references: [id])
  brandPersona         BrandPersona?             @relation(fields: [brandPersonaId], references: [id])
  ideasFramework       IdeasFramework?           @relation(fields: [ideasFrameworkId], references: [id])
  contentPrinciples    ContentCreationPrinciples? @relation(fields: [contentPrinciplesId], references: [id])
  renderJob            RenderJob?                       // v2: Async render job
}

/// v2: Async render job queue — tracks render status for compositions
model RenderJob {
  id            String      @id @default(cuid())
  compositionId String      @unique
  status        String      @default("queued")    // queued | rendering | uploading | done | failed
  progress      Float       @default(0)
  outputUrl     String?                           // R2 URL of rendered output
  outputType    String      @default("video")     // video | image | images
  error         String?     @db.Text
  attempts      Int         @default(0)
  maxAttempts   Int         @default(3)
  startedAt     DateTime?
  completedAt   DateTime?
  renderTimeMs  Int?                              // Performance tracking
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  composition   Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
}

/// v2: Daily content plan — tracks what content is planned for each day per account
model ContentPlan {
  id          String        @id @default(cuid())
  accountId   String
  date        DateTime      @db.Date             // Calendar date (no time component)
  pieces      Json                               // Array of planned content piece summaries
  scripts     Json?                              // Pending head-talk recording scripts
  delivered   Boolean       @default(false)      // Whether plan was delivered via Zazŭ
  deliveredAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  account     SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
}

model ContentPlanner {
  id                  String        @id @default(cuid())
  accountId           String
  name                String        // e.g. "Conservative Daily", "Aggressive Growth"
  isDefault           Boolean       @default(false)
  autoApproveSchedule Boolean       @default(false)
  strategistPrompt    String?       @db.Text             // Phase 18: AI strategist system prompt
  daysToPlan          Int           @default(7)           // Phase 18: planning horizon

  frequencyDays       Int           @default(1) // E.g., post every X days
  reelsPerDay         Int           @default(5)
  trialReelsPerDay    Int           @default(5)
  postingTimes        Json          @default("[]")        // Array of HH:MM strings
  trialPostingTimes   Json          @default("[]")
  timezone            String        @default("Europe/Madrid")
  lastPostedAt        DateTime?

  account             SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, name])
}
