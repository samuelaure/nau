generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ── Brand ──────────────────────────────────────────────────────────────────────
// Local flownau mirror of the 9naŭ Brand.  id = 9naŭ Brand.id.
// Stores flownau-specific pipeline config (prompts, short code, assets root).
// Content pipeline (ideas, compositions, plans, templates, assets) is anchored here.
model Brand {
  id             String   @id            // = 9naŭ Brand.id
  workspaceId    String                  // = 9naŭ Workspace.id
  name           String?                 // cached from 9naŭ API
  shortCode      String?
  assetsRoot     String?
  language       String   @default("Spanish")
  directorPrompt String?  @db.Text
  creationPrompt String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  socialProfiles       SocialProfile[]
  assets               Asset[]
  templates            Template[]
  brandTemplateConfigs BrandTemplateConfig[]
  contentIdeas         ContentIdea[]
  compositions         Composition[]
  contentPlans         ContentPlan[]
}

// ── SocialProfile ──────────────────────────────────────────────────────────────
// A posting channel — the endpoint of the brand's content pipeline.
// One brand can have many social profiles (Instagram today, more platforms soon).
model SocialProfile {
  id               String    @id @default(cuid())
  brandId          String
  brand            Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  workspaceId      String
  platform         String    @default("instagram")
  platformId       String?
  username         String?
  profileImage     String?
  accessToken      String
  refreshToken     String?
  expiresAt        DateTime?
  tokenExpiresAt   DateTime?
  tokenRefreshedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([platform, platformId])
}

model Asset {
  id               String    @id @default(cuid())
  brandId          String?
  templateId       String?
  type             String
  systemFilename   String
  originalFilename String
  r2Key            String
  url              String
  size             Int
  mimeType         String
  hash             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  thumbnailUrl     String?
  duration         Float?
  description      String?   @db.Text
  tags             String[]  @default([])
  lastUsedAt       DateTime?
  usageCount       Int       @default(0)

  brand    Brand?    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  template Template? @relation(fields: [templateId], references: [id])
}

model Template {
  id               String    @id @default(cuid())
  name             String
  remotionId       String
  config           Json?
  brandId          String
  scope            String    @default("brand")
  useBrandAssets   Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  assetsRoot       String?
  systemPrompt     String?   @db.Text
  creationPrompt   String?   @db.Text
  captionPrompt    String?   @db.Text
  schemaJson       Json?
  contentSchema    Json?
  sceneType        String?
  slotSchema       Json?
  styleConfig      Json?

  renders      Render[]
  assets       Asset[]
  compositions Composition[]
  brandConfigs BrandTemplateConfig[]
  brand        Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

model BrandTemplateConfig {
  id              String   @id @default(cuid())
  brandId         String
  templateId      String
  autoApprovePost Boolean  @default(false)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([brandId, templateId])
}

/// DEPRECATED: Legacy render tracking. Use RenderJob instead.
model Render {
  id               String   @id @default(cuid())
  templateId       String
  status           String   @default("IDLE")
  progress         Float    @default(0)
  inputData        Json?
  r2Url            String?
  instagramMediaId String?
  instagramStatus  String?
  error            String?
  renderLog        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  template         Template @relation(fields: [templateId], references: [id])
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AIModel {
  GROQ_LLAMA_3_3
  GROQ_LLAMA_3_1_70B
  GROQ_LLAMA_3_1_8B
  GROQ_MIXTRAL_8X7B
  GROQ_DEEPSEEK_R1_70B
  OPENAI_GPT_4O
  OPENAI_GPT_4O_MINI
  OPENAI_GPT_4_TURBO
  OPENAI_GPT_4_1
  OPENAI_O1
  OPENAI_O1_MINI
}

model BrandPersona {
  id                      String   @id @default(cuid())
  brandId                 String   // 9naŭ Brand.id
  workspaceId             String   // 9naŭ Workspace.id
  name                    String
  systemPrompt            String   @db.Text
  modelSelection          AIModel  @default(GROQ_LLAMA_3_3)
  isDefault               Boolean  @default(false)
  autoApproveIdeas        Boolean  @default(false)
  autoApproveCompositions Boolean  @default(false)
  autoApprovePool         Boolean  @default(false)
  capturedAutoApprove     Boolean  @default(false)
  capturedCount           Int      @default(3)
  manualAutoApprove       Boolean  @default(false)
  manualCount             Int      @default(5)
  automaticAutoApprove    Boolean  @default(false)
  automaticCount          Int      @default(5)

  ideas        ContentIdea[]
  compositions Composition[]
}

model IdeasFramework {
  id           String   @id @default(cuid())
  brandId      String   // 9naŭ Brand.id
  workspaceId  String   // 9naŭ Workspace.id
  name         String
  systemPrompt String   @db.Text
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ideas        ContentIdea[]
  compositions Composition[]
}

model ContentCreationPrinciples {
  id           String   @id @default(cuid())
  brandId      String   // 9naŭ Brand.id
  workspaceId  String   // 9naŭ Workspace.id
  name         String
  systemPrompt String   @db.Text
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ideas        ContentIdea[]
  compositions Composition[]
}

model ContentIdea {
  id                  String    @id @default(cuid())
  brandId             String
  ideaText            String    @db.Text
  format              String?
  status              String    @default("PENDING")
  source              String    @default("automatic")
  sourceRef           String?
  priority            Int       @default(3)
  aiLinked            Boolean   @default(false)
  createdAt           DateTime  @default(now())
  brandPersonaId      String?
  ideasFrameworkId    String?
  contentPrinciplesId String?

  compositions      Composition[]
  brand             Brand                      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandPersona      BrandPersona?              @relation(fields: [brandPersonaId], references: [id])
  ideasFramework    IdeasFramework?            @relation(fields: [ideasFrameworkId], references: [id])
  contentPrinciples ContentCreationPrinciples? @relation(fields: [contentPrinciplesId], references: [id])
}

model Composition {
  id                   String    @id @default(cuid())
  brandId              String
  templateId           String?
  format               String    @default("reel")
  creative             Json?
  payload              Json
  videoUrl             String?
  coverUrl             String?
  caption              String?   @db.Text
  hashtags             String[]  @default([])
  externalPostId       String?
  externalPostUrl      String?
  source               String    @default("composed")
  status               String    @default("DRAFT")
  scheduledAt          DateTime?
  publishAttempts      Int       @default(0)
  lastPublishError     String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  ideaId               String?
  sceneTypes           String[]  @default([])
  topicHash            String?
  brandPersonaId       String?
  ideasFrameworkId     String?
  contentPrinciplesId  String?
  userUploadedMediaUrl String?
  userPostedManually   Boolean   @default(false)

  brand             Brand                      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  template          Template?                  @relation(fields: [templateId], references: [id])
  idea              ContentIdea?               @relation(fields: [ideaId], references: [id])
  brandPersona      BrandPersona?              @relation(fields: [brandPersonaId], references: [id])
  ideasFramework    IdeasFramework?            @relation(fields: [ideasFrameworkId], references: [id])
  contentPrinciples ContentCreationPrinciples? @relation(fields: [contentPrinciplesId], references: [id])
  renderJob         RenderJob?
}

model RenderJob {
  id            String      @id @default(cuid())
  compositionId String      @unique
  status        String      @default("queued")
  progress      Float       @default(0)
  outputUrl     String?
  outputType    String      @default("video")
  error         String?     @db.Text
  attempts      Int         @default(0)
  maxAttempts   Int         @default(3)
  startedAt     DateTime?
  completedAt   DateTime?
  renderTimeMs  Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  composition Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
}

model ContentPlan {
  id          String   @id @default(cuid())
  brandId     String
  date        DateTime @db.Date
  pieces      Json
  scripts     Json?
  delivered   Boolean  @default(false)
  deliveredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, date])
}

model ContentPlanner {
  id                  String   @id @default(cuid())
  brandId             String   // 9naŭ Brand.id
  workspaceId         String   // 9naŭ Workspace.id
  name                String
  isDefault           Boolean  @default(false)
  autoApproveSchedule Boolean  @default(false)
  strategistPrompt    String?  @db.Text
  daysToPlan          Int      @default(7)
  frequencyDays       Int      @default(1)
  reelsPerDay         Int      @default(5)
  trialReelsPerDay    Int      @default(5)
  postingTimes        Json     @default("[]")
  trialPostingTimes   Json     @default("[]")
  timezone            String   @default("Europe/Madrid")
  lastPostedAt        DateTime?

  @@unique([brandId, name])
}
