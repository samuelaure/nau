generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ── Social Profiles ───────────────────────────────────────────────────────────

model IgProfile {
  username        String    @id
  profileImageUrl String?
  lastScrapedAt   DateTime  @default(now())

  posts           Post[]
  targets         BrandTarget[]
}

// ── Scraped Content ───────────────────────────────────────────────────────────

model Post {
  id              String    @id @default(uuid())
  instagramId     String?   @unique
  instagramUrl    String    @unique
  username        String?
  igProfile       IgProfile? @relation(fields: [username], references: [username])
  caption         String?
  originalCaption String?
  postedAt        DateTime
  likes           Int       @default(0)
  comments        Int       @default(0)
  views           Int?
  engagementScore Float?
  collaborators   Json?
  intelligence    Json?

  runId           String?
  run             ScrapingRun? @relation(fields: [runId], references: [id])

  media           Media[]
  transcripts     Transcript[]
  feedbacks       CommentFeedback[]
  inspoItems      InspoItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([username, postedAt(sort: Desc)])
}

model ScrapingRun {
  id          String   @id @default(uuid())
  username    String
  actorRunId  String?  @unique
  datasetId   String?
  rawData     Json?
  status      String   @default("completed")
  phase       String   @default("finished")
  isPaused    Boolean  @default(false)

  posts       Post[]

  createdAt   DateTime @default(now())
}

model Media {
  id           String      @id @default(uuid())
  postId       String
  post         Post        @relation(fields: [postId], references: [id])
  type         String
  url          String?
  storageUrl   String
  thumbnailUrl String?
  duration     Float?
  index        Int         @default(0)

  transcript   Transcript?

  createdAt    DateTime @default(now())

  @@index([postId])
}

model Transcript {
  id           String     @id @default(uuid())
  postId       String
  post         Post       @relation(fields: [postId], references: [id])
  mediaId      String?    @unique
  media        Media?     @relation(fields: [mediaId], references: [id])
  text         String
  originalText String?
  json         Json?

  createdAt    DateTime @default(now())

  embeddings   Embedding[]
  knowledgeChunks KnowledgeChunk[]

  @@index([postId])
}

model Embedding {
  id           String     @id @default(uuid())
  transcriptId String     @unique
  transcript   Transcript @relation(fields: [transcriptId], references: [id])
  vector       Unsupported("vector(1536)")
  model        String     @default("text-embedding-3-small")

  createdAt    DateTime @default(now())
}

// ── Knowledge / RAG ───────────────────────────────────────────────────────────

model KnowledgeChunk {
  id           String   @id @default(uuid())
  platform     String
  platformId   String
  brandId      String?
  sourceType   String   @default("transcript")
  sourceId     String?
  chunkIndex   Int      @default(0)
  text         String
  vector       Unsupported("vector(1536)")
  model        String   @default("text-embedding-3-small")

  transcriptId String?
  transcript   Transcript? @relation(fields: [transcriptId], references: [id])

  createdAt    DateTime @default(now())

  @@index([platform, platformId])
  @@index([brandId])
}

// ── Brand Intelligence ────────────────────────────────────────────────────────

model BrandIntelligence {
  brandId           String   @id
  workspaceId       String   @default("")
  mainIgUsername    String?
  voicePrompt       String
  commentStrategy   String?
  suggestionsCount  Int      @default(3)
  windowStart       String?
  windowEnd         String?
  timezone          String   @default("UTC")
  inspoRequestCount Int      @default(0)

  targets    BrandTarget[]
  syntheses  BrandSynthesis[]
  feedbacks  CommentFeedback[]
  inspoItems InspoItem[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([workspaceId])
}

model BrandSynthesis {
  id           String   @id @default(uuid())
  brandId      String
  brand        BrandIntelligence @relation(fields: [brandId], references: [brandId], onDelete: Cascade)
  type         String
  content      String   @db.Text
  attachedUrls Json     @default("[]")

  createdAt    DateTime @default(now())

  @@index([brandId, type])
}

model BrandTarget {
  id                   String   @id @default(uuid())
  brandId              String
  brand                BrandIntelligence @relation(fields: [brandId], references: [brandId])
  username             String
  igProfile            IgProfile @relation(fields: [username], references: [username])
  profileStrategy      String?
  targetType           String   @default("monitored")
  isActive             Boolean  @default(true)
  initialDownloadCount Int?     @default(20)
  autoUpdate           Boolean? @default(false)

  createdAt            DateTime @default(now())

  @@unique([brandId, username])
  @@index([brandId, targetType])
}

model CommentFeedback {
  id          String   @id @default(uuid())
  brandId     String
  brand       BrandIntelligence @relation(fields: [brandId], references: [brandId])
  postId      String
  post        Post     @relation(fields: [postId], references: [id])
  commentText String   @db.Text
  isSelected  Boolean  @default(false)

  sentAt      DateTime @default(now())

  @@index([brandId])
}

// ── Inspo ─────────────────────────────────────────────────────────────────────

model InspoItem {
  id              String   @id @default(uuid())
  brandId         String
  brand           BrandIntelligence @relation(fields: [brandId], references: [brandId], onDelete: Cascade)
  postId          String?
  post            Post?    @relation(fields: [postId], references: [id])
  sourceUrl       String?
  type            String
  note            String?  @db.Text
  status          String   @default("pending")
  extractedHook   String?  @db.Text
  extractedTheme  String?
  adaptedScript   String?  @db.Text
  injectedContext String?  @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([brandId])
  @@index([brandId, status])
}
