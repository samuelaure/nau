generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ── Scraped Content ───────────────────────────────────────────────────────────

/// Post scraped from any social platform.
/// Keyed by (platform, platformId) for dedup — multiple brands can monitor the same profile.
model Post {
  id          String   @id @default(uuid())
  platform    String   @default("INSTAGRAM")
  platformId  String   // platform-native post ID
  url         String   @unique
  username    String?
  caption     String?
  postedAt    DateTime
  likes       Int      @default(0)
  comments    Int      @default(0)
  views       Int?
  engagementScore Float?
  collaborators   Json?
  intelligence    Json?

  runId       String?
  run         ScrapingRun?    @relation(fields: [runId], references: [id])

  media       Media[]
  transcripts Transcript[]
  feedbacks   CommentFeedback[]
  inspoItems  InspoItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([platform, platformId])
  @@index([username, postedAt(sort: Desc)])
  @@index([platform, username])
}

model ScrapingRun {
  id         String   @id @default(uuid())
  brandId    String   @default("")
  platform   String   @default("INSTAGRAM")
  username   String
  actorRunId String?  @unique
  datasetId  String?
  rawData    Json?
  status     String   @default("completed")
  phase      String   @default("finished")
  isPaused   Boolean  @default(false)

  posts      Post[]

  createdAt  DateTime @default(now())

  @@index([brandId])
}

model Media {
  id           String     @id @default(uuid())
  postId       String
  post         Post       @relation(fields: [postId], references: [id])
  type         String
  url          String?
  storageUrl   String
  thumbnailUrl String?
  duration     Float?
  index        Int        @default(0)

  transcript   Transcript?

  createdAt    DateTime @default(now())

  @@index([postId])
}

model Transcript {
  id           String     @id @default(uuid())
  postId       String
  post         Post       @relation(fields: [postId], references: [id])
  mediaId      String?    @unique
  media        Media?     @relation(fields: [mediaId], references: [id])
  text         String
  originalText String?
  json         Json?

  createdAt    DateTime @default(now())

  knowledgeChunks KnowledgeChunk[]

  @@index([postId])
}

// ── Knowledge / RAG ───────────────────────────────────────────────────────────

/// Generic chunked content for pgvector RAG.
/// Replaces the old Embedding model — supports chunking policies beyond transcript-only.
model KnowledgeChunk {
  id           String   @id @default(uuid())
  platform     String
  platformId   String   // platformId of the source post/profile
  brandId      String?  // null = shared across all brands monitoring this profile
  sourceType   String   @default("transcript") // transcript | caption | synthesis | inspo
  sourceId     String?  // transcript.id or other source row id
  chunkIndex   Int      @default(0)
  text         String
  vector       Unsupported("vector(1536)")
  model        String   @default("text-embedding-3-small")

  transcriptId String?
  transcript   Transcript? @relation(fields: [transcriptId], references: [id])

  createdAt    DateTime @default(now())

  @@index([platform, platformId])
  @@index([brandId])
}

// ── Brand-scoped entities ──────────────────────────────────────────────────────

/// Inspiration item captured by user.
/// brandId = 9naŭ API Brand.id (referenced, not owned)
model InspoItem {
  id             String   @id @default(uuid())
  brandId        String
  postId         String?
  post           Post?    @relation(fields: [postId], references: [id])
  sourceUrl      String?
  type           String
  note           String?  @db.Text
  status         String   @default("pending")
  extractedHook  String?  @db.Text
  extractedTheme String?
  adaptedScript  String?  @db.Text
  injectedContext String? @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([brandId])
  @@index([brandId, status])
}

/// AI-generated pattern/theme digest for a brand or monitored profile.
model BrandSynthesis {
  id           String   @id @default(uuid())
  brandId      String
  type         String
  content      String   @db.Text
  attachedUrls Json     @default("[]")
  createdAt    DateTime @default(now())

  @@index([brandId, type])
}

/// Feedback on comment suggestions — tracks which variant was chosen.
model CommentFeedback {
  id          String   @id @default(uuid())
  brandId     String
  postId      String
  post        Post     @relation(fields: [postId], references: [id])
  commentText String   @db.Text
  isSelected  Boolean  @default(false)
  sentAt      DateTime @default(now())

  @@index([brandId])
}
