generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ── Social Profiles ───────────────────────────────────────────────────────────
// A SocialProfile is any external social media account we scrape/monitor.
// platform: instagram | tiktok | youtube | ...
// ownerId: the Brand that owns/publishes to this profile (one brand per profile per platform)

model SocialProfile {
  id              String   @id @default(uuid())
  platform        String   @default("instagram")
  username        String
  externalId      String?  // Instagram's stable numeric profile ID — never changes even if username does
  profileImageUrl String?
  totalPostCount  Int?
  lastScrapedAt   DateTime @default(now())

  // How many new synthesized posts trigger a soft-update of the profile synthesis (min 36)
  synthesisTriggerThreshold Int @default(36)

  // Ownership — the ONE brand that publishes to this profile
  ownerId String?
  owner   Brand?  @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  posts                  Post[]
  categoryMemberships    CategoryMembership[]
  syncSnapshots          ProfileSyncSnapshot[]
  profileSynthesis       ProfileSynthesis?
  profileSynthesisHistory ProfileSynthesisHistory[]
  sourceConceptSources   SourceConceptSource[]
  trashItems             TrashItem[]

  @@unique([platform, username])
  @@index([platform, username])
  @@index([ownerId])
}

model ProfileSyncSnapshot {
  id              String        @id @default(uuid())
  socialProfileId String
  socialProfile   SocialProfile @relation(fields: [socialProfileId], references: [id], onDelete: Cascade)

  igPostCount     Int
  nauPostCount    Int
  scrapeTriggered Boolean       @default(false)

  createdAt DateTime @default(now())

  @@index([socialProfileId, createdAt(sort: Desc)])
}

// ── Scraped Content ───────────────────────────────────────────────────────────

model Post {
  id              String         @id @default(uuid())
  platformId      String?        @unique
  url             String         @unique
  username        String?
  socialProfileId String?
  socialProfile   SocialProfile? @relation(fields: [socialProfileId], references: [id])
  caption         String?
  originalCaption String?
  postedAt        DateTime
  likes           Int            @default(0)
  comments        Int            @default(0)
  views           Int?
  engagementScore Float?
  collaborators   Json?
  intelligence    Json?
  postSynthesis   String?  @db.Text
  synthesisTrace  Json?
  status          String   @default("pending")

  runId String?
  run   ScrapingRun? @relation(fields: [runId], references: [id])

  media               Media[]
  transcripts         Transcript[]
  feedbacks            CommentFeedback[]
  categoryMemberships  CategoryMembership[]
  sourceConceptSources SourceConceptSource[]
  trashItems           TrashItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([socialProfileId, postedAt(sort: Desc)])
  @@index([username, postedAt(sort: Desc)])
}

model ScrapingRun {
  id         String  @id @default(uuid())
  username   String
  actorRunId String? @unique
  datasetId  String?
  rawData    Json?
  status     String  @default("completed")
  phase      String  @default("finished")
  isPaused   Boolean @default(false)

  posts Post[]

  createdAt DateTime @default(now())
}

model Media {
  id           String  @id @default(uuid())
  postId       String
  post         Post    @relation(fields: [postId], references: [id])
  type         String
  url          String?
  storageUrl   String
  thumbnailUrl String?
  duration     Float?
  index        Int     @default(0)

  transcript Transcript?

  createdAt DateTime @default(now())

  @@index([postId])
}

model Transcript {
  id           String  @id @default(uuid())
  postId       String
  post         Post    @relation(fields: [postId], references: [id])
  mediaId      String? @unique
  media        Media?  @relation(fields: [mediaId], references: [id])
  text         String
  originalText String?
  json         Json?

  createdAt DateTime @default(now())

  embeddings      Embedding[]
  knowledgeChunks KnowledgeChunk[]

  @@index([postId])
}

model Embedding {
  id           String                      @id @default(uuid())
  transcriptId String                      @unique
  transcript   Transcript                  @relation(fields: [transcriptId], references: [id])
  vector       Unsupported("vector(1536)")
  model        String                      @default("text-embedding-3-small")

  createdAt DateTime @default(now())
}

// ── Knowledge / RAG ───────────────────────────────────────────────────────────

model KnowledgeChunk {
  id         String                      @id @default(uuid())
  platform   String
  platformId String
  brandId    String?
  sourceType String                      @default("transcript")
  sourceId   String?
  chunkIndex Int                         @default(0)
  text       String
  vector     Unsupported("vector(1536)")
  model      String                      @default("text-embedding-3-small")

  transcriptId String?
  transcript   Transcript? @relation(fields: [transcriptId], references: [id])

  createdAt DateTime @default(now())

  @@index([platform, platformId])
  @@index([brandId])
}

// ── Brand ─────────────────────────────────────────────────────────────────────
// Brand represents a brand's intelligence/configuration in nauthenticity.
// id = flownau Brand.id (same as API Brand.id)

// ── Project ───────────────────────────────────────────────────────────────────
// Mirror of api's Project. Holds the same id; nauthenticity uses it as the
// ownership anchor for ProjectMemberships (same role as Brand for categories).

model Project {
  id          String  @id // = api Project.id
  workspaceId String
  brandId     String?
  name        String
  isActive    Boolean @default(true)

  categoryMemberships CategoryMembership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

enum FreshnessUnit {
  WEEKS
  MONTHS
}

model Brand {
  id                           String        @id // = flownau Brand.id = API Brand.id
  workspaceId                  String        @default("")
  mainUsername                 String?
  commentPrompt                String?
  suggestionsCount             Int           @default(3)
  windowStart                  String?
  windowEnd                    String?
  timezone                     String        @default("UTC")
  language                     String        @default("Spanish")
  inspoRequestCount            Int           @default(0)
  sourceConceptFreshnessPeriod Int           @default(2)
  sourceConceptFreshnessUnit   FreshnessUnit @default(WEEKS)

  ownedProfiles       SocialProfile[]
  categoryMemberships CategoryMembership[]
  sourceConcepts      SourceConcept[]
  voicenotes          Voicenote[]
  context             BrandContext?
  feedbacks           CommentFeedback[]
  trashItems          TrashItem[]
  youtubeVideos       YoutubeVideo[]
  blogPosts           BlogPost[]

  youtubeDurationExceededCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

// ── SourceConcept ─────────────────────────────────────────────────────────────
// A distilled idea angle extracted from an InspoBase (or future: voicenote, specific capture).
// Each pending concept drives one idea-generation batch in flownau.
// sourceType values: 'inspo_base' | 'voicenote' | 'specific_post' | 'specific_profile'
// status values: 'pending' | 'consumed'
model SourceConcept {
  id         String    @id @default(uuid())
  brandId    String
  brand      Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  content    String    @db.Text
  sourceType String    @default("inspo_base")
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  consumedAt DateTime?

  sources SourceConceptSource[]

  @@index([brandId, status])
}

// Links a SourceConcept back to the specific post(s) or profile it was derived from.
model SourceConceptSource {
  id              String        @id @default(uuid())
  sourceConceptId String
  sourceConcept   SourceConcept @relation(fields: [sourceConceptId], references: [id], onDelete: Cascade)
  postId          String?
  post            Post?         @relation(fields: [postId], references: [id], onDelete: SetNull)
  socialProfileId String?
  socialProfile   SocialProfile? @relation(fields: [socialProfileId], references: [id], onDelete: SetNull)

  @@index([sourceConceptId])
  @@index([postId])
  @@index([socialProfileId])
}

// ── Profile Synthesis ─────────────────────────────────────────────────────────
// A holistic LLM-generated synthesis of a social profile derived from its posts' syntheses.
// One per profile (upserted). Previous versions archived in ProfileSynthesisHistory.
model ProfileSynthesis {
  id                   String        @id @default(uuid())
  socialProfileId      String        @unique
  socialProfile        SocialProfile @relation(fields: [socialProfileId], references: [id], onDelete: Cascade)
  content              String        @db.Text
  postCountAtGeneration Int
  synthesisTrace       Json?
  generatedAt          DateTime      @default(now())
}

// Archives previous ProfileSynthesis values before overwrite.
model ProfileSynthesisHistory {
  id                   String        @id @default(uuid())
  socialProfileId      String
  socialProfile        SocialProfile @relation(fields: [socialProfileId], references: [id], onDelete: Cascade)
  content              String        @db.Text
  postCountAtGeneration Int
  generatedAt          DateTime
  archivedAt           DateTime      @default(now())

  @@index([socialProfileId, archivedAt(sort: Desc)])
}

// ── Voicenote ─────────────────────────────────────────────────────────────────
// A voicenote capture sent from Zazŭ. Stores the processed transcription and
// synthesis received from Zazŭ. Drives SourceConcept generation per brand.

model Voicenote {
  id               String    @id @default(uuid())
  brandId          String
  brand            Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  cleanTranscription String  @db.Text
  synthesis        String    @db.Text
  sourceRef        String?   // zazu-bot Voicenote.id
  createdAt        DateTime  @default(now())

  @@index([brandId])
}

// ── Brand Context ──────────────────────────────────────────────────────────────
// Structured brand identity context generated from owned posts, InspoBase,
// previous context, and/or manual input. Pushed to flownau on every write.

model BrandContext {
  id          String    @id @default(uuid())
  brandId     String    @unique
  brand       Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  status      String    @default("idle") // idle | generating | ready | failed
  content          String?   // Plain-text brand context (rendered from generated JSON, user-editable)
  customAdditions  String?   // User-written additions — persists across regeneration
  sources          Json?     // { ownedProfile: bool, inspoBase: bool, previousContext: bool, manual: string|null }
  generatedAt      DateTime?
  updatedAt        DateTime  @updatedAt
}

// CategoryMembership links a Brand to either a SocialProfile or a Post under one of the
// non-OWN categories. OWN ownership lives separately on SocialProfile.ownerId (1:1).
//
// category values:
//   "COMMENT"   — proactive comment-suggestion monitoring (profile-level only)
//   "INSPO"     — InspoBase membership (profile-level OR post-level)
//   "BENCHMARK" — benchmark/study membership (profile-level OR post-level); also the default-
//                 absorption sink: when a profile/post is removed from INSPO and COMMENT and
//                 has no other membership, it is moved to BENCHMARK rather than deleted.
//
// Exactly one of (socialProfileId, postId) must be set per row.
model CategoryMembership {
  id              String         @id @default(uuid())
  brandId         String?
  brand           Brand?         @relation(fields: [brandId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  socialProfileId String?
  socialProfile   SocialProfile? @relation(fields: [socialProfileId], references: [id], onDelete: Cascade)
  postId          String?
  post            Post?          @relation(fields: [postId], references: [id], onDelete: Cascade)
  youtubeVideoId  String?
  youtubeVideo    YoutubeVideo?  @relation(fields: [youtubeVideoId], references: [id], onDelete: Cascade)
  blogPostId      String?
  blogPost        BlogPost?      @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  category        String
  isActive        Boolean        @default(true)
  commentPrompt   String?

  createdAt DateTime @default(now())

  // Note: actual uniqueness is enforced by two partial unique indexes (raw SQL in migration):
  //   - (brandId, category, socialProfileId) WHERE postId IS NULL
  //   - (brandId, category, postId)          WHERE socialProfileId IS NULL
  // Postgres treats NULL as distinct in standard unique constraints, so we use partial indexes instead.
  @@index([brandId, category])
  @@index([socialProfileId])
  @@index([postId])
}

model CommentFeedback {
  id          String  @id @default(uuid())
  brandId     String
  brand       Brand   @relation(fields: [brandId], references: [id])
  postId      String
  post        Post    @relation(fields: [postId], references: [id])
  commentText String  @db.Text
  isSelected  Boolean @default(false)

  sentAt DateTime @default(now())

  @@index([brandId])
}

model TrashItem {
  id               String         @id @default(uuid())
  brandId          String
  brand            Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  socialProfileId  String?
  socialProfile    SocialProfile? @relation(fields: [socialProfileId], references: [id], onDelete: Cascade)
  postId           String?
  post             Post?          @relation(fields: [postId], references: [id], onDelete: Cascade)
  youtubeVideoId   String?
  youtubeVideo     YoutubeVideo?  @relation(fields: [youtubeVideoId], references: [id], onDelete: Cascade)
  blogPostId       String?
  blogPost         BlogPost?      @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  originalCategory String
  deletedAt        DateTime       @default(now())
  expiresAt        DateTime

  @@index([brandId])
  @@index([expiresAt])
}

// ── YouTube Videos ────────────────────────────────────────────────────────────
// A YouTube video added to a brand's InspoBase. Status lifecycle: pending → processing → ready | failed.

model YoutubeVideo {
  id              String   @id @default(uuid())
  brandId         String
  brand           Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  url             String
  videoId         String
  title           String?
  channelName     String?
  durationSeconds Int?
  transcript      String?  @db.Text
  synthesis       String?  @db.Text
  status          String   @default("pending")
  failureReason   String?
  createdAt       DateTime @default(now())

  categoryMemberships CategoryMembership[]
  trashItems          TrashItem[]

  @@unique([brandId, videoId])
  @@index([brandId, status])
}

// ── Blog Posts ────────────────────────────────────────────────────────────────
// A blog post URL added to a brand's InspoBase. Status lifecycle: pending → processing → ready | failed.

model BlogPost {
  id            String    @id @default(uuid())
  brandId       String
  brand         Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  url           String
  title         String?
  author        String?
  publishedAt   DateTime?
  rawText       String?   @db.Text
  synthesis     String?   @db.Text
  status        String    @default("pending")
  failureReason String?
  createdAt     DateTime  @default(now())

  categoryMemberships CategoryMembership[]
  trashItems          TrashItem[]

  @@unique([brandId, url])
  @@index([brandId, status])
}

