# --- Core ---
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# --- Database ---
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=nauthenticity

# --- Redis ---
REDIS_PASSWORD=

# --- Auth ---
# Shared HS256 secret — must be identical across all platform services
AUTH_SECRET=

# --- CORS ---
ALLOWED_ORIGINS=https://nauthenticity.9nau.com,https://flownau.9nau.com

# --- Internal service URLs (Docker network) ---
FLOWNAU_URL=http://flownau:3000
FRONTEND_URL=https://flownau.9nau.com

# --- AI ---
OPENAI_API_KEY=

# --- Scraping ---
APIFY_TOKEN=
APIFY_INSTAGRAM_UNIVERSAL_ACTOR_ID=

# --- Storage (Cloudflare R2) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=nau-storage
R2_PUBLIC_URL=

# --- Service identity ---
NAU_SERVICE_KEY=

# --- Optional ---
TRANSCRIPTION_URL=
PAUSE_COMPUTE=false
