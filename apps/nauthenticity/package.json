{
  "name": "nauthenticity",
  "version": "2.0.0",
  "description": "Brand intelligence service — scraping, transcription, semantic search, InspoBase, comment suggestions",
  "main": "dist/main.js",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "dev": "dotenv -e ../../.env.development -e .env.development -- nest start --watch",
    "predev": "dotenv -e ../../.env.development -e .env.development -- npx prisma migrate deploy && dotenv -e ../../.env.development -e .env.development -- npx prisma generate && node -e \"const fs=require('fs');try{fs.unlinkSync('tsconfig.tsbuildinfo')}catch(e){}\" && npx nest build",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:ci": "jest --coverage --ci --forceExit"
  },
  "dependencies": {
    "@nau/auth": "workspace:*",
    "@nau/config": "workspace:*",
    "@nau/llm-client": "workspace:*",
    "@nau/logger": "workspace:*",
    "@nau/sdk": "workspace:*",
    "@nau/types": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "apify-client": "^2.22.0",
    "bullmq": "^5.67.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "nau-storage": "^0.1.1",
    "openai": "^6.16.0",
    "pg": "^8.20.0",
    "pino": "^9.6.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "*",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.1.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.7",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
