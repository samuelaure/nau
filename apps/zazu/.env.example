# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=
LOG_LEVEL=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET=

# ── Telegram ──────────────────────────────────────────────────────────────────
# Use a dedicated dev bot from @BotFather for local development.
# Production bot can only run one polling instance — do not use it locally.
TELEGRAM_BOT_TOKEN=
BOT_DOMAIN=
# Set to true to skip Telegram polling (e.g. when using the production token locally).
SKIP_TELEGRAM_POLLING=
# Admin's Telegram chat ID — used to forward platform system notifications.
ADMIN_TELEGRAM_ID=

# ── Internal service URLs ─────────────────────────────────────────────────────
NAU_API_URL=
NAUTHENTICITY_URL=

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Storage (Cloudflare R2) ───────────────────────────────────────────────────
# Files stored under {NODE_ENV}/zazu/ prefix in the shared nau-storage bucket.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Make.com integrations ────────────────────────────────────────────────────
# YouTube digester — Make.com webhook URL for processing YouTube video links.
MAKE_YOUTUBE_WEBHOOK_URL=
# Static secret sent by Make.com in `x-callback-secret` header for the callback endpoint.
MAKE_CALLBACK_SECRET=

# ── nispiras ─────────────────────────────────────────────────────────────
# Static secret sent by nispiras Android app in `x-nispiras-secret` header.
NISPIRAS_WEBHOOK_SECRET=

# ── nau-web ───────────────────────────────────────────────────────────────
# Static secret sent by nau-web Express server in `x-nau-web-secret` header.
NAU_WEB_WEBHOOK_SECRET=
