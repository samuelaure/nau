# API Test Environment Variables
# This file is a template. Copy it to .env.test and fill in your actual values.

NODE_ENV=test

PORT=${API_PORT}
ALLOWED_ORIGINS="http://localhost:${WEB_PORT},http://localhost:3002,http://localhost:5173"

# DATABASE_URL is constructed using variables from the root .env.test file
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"
