{
  "name": "@9nau/api",
  "version": "0.1.1",
  "private": true,
  "description": "The back-end API for the 9naŭ platform.",
  "license": "UNLICENSED",
  "author": "Samuel Aure",
  "scripts": {
    "build": "nest build",
    "dev:db:migrate:deploy": "dotenv -e ../../.env.development -e .env.development -- npx prisma migrate deploy",
    "dev:db:reset": "dotenv -e ../../.env.development -e .env.development -- npx prisma migrate reset --force --skip-seed",
    "dev:db:seed": "dotenv -e ../../.env.development -e .env.development -- ts-node prisma/seed.ts",
    "dev": "dotenv -e ../../.env.development -e .env.development -- nest start --watch",
    "predev": "dotenv -e ../../.env.development -e .env.development -- npx prisma migrate deploy && dotenv -e ../../.env.development -e .env.development -- npx prisma generate --schema=prisma/schema.prisma",
    "dev:prisma:g": "dotenv -e ../../.env.development -e .env.development -- npx prisma generate",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prod:on": "pnpm run prod:prisma:g && dotenv -e ../../.env -e .env -- nest start --watch",
    "prod:prisma:g": "dotenv -e ../../.env -e .env -- npx prisma generate",
    "start": "nest start",
    "start:debug": "dotenv -e ../../.env -e .env -- nest start --debug --watch",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:db:migrate:deploy": "dotenv -e ../../.env.test -e .env.test -- npx prisma migrate deploy",
    "test:db:reset": "dotenv -e ../../.env.test -e .env.test -- npx prisma migrate reset --force --skip-seed",
    "test:db:seed": "dotenv -e ../../.env.test -e .env.test -- ts-node prisma/seed.ts",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:on": "pnpm run test:db:reset && pnpm run test:db:migrate:deploy && dotenv -e ../../.env.test -e .env.test -- nest start --watch",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@nau/auth": "workspace:*",
    "@nau/llm-client": "workspace:*",
    "@nau/types": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^7.8.0",
    "@types/bcryptjs": "^3.0.0",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.20",
    "dotenv": "^17.2.1",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nau-storage": "^0.1.1",
    "openai": "^6.34.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^2.1.0",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^7.4.4",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.7",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0"
  }
}
