# --- Core ---
NODE_ENV=production
PORT=3000

# --- Database ---
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=nau_api

# --- Redis ---
REDIS_PASSWORD=

# --- Auth ---
