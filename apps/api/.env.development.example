# API Development Environment Variables
# This file is a template. Copy it to .env and fill in your actual values.

NODE_ENV=development

PORT=${API_PORT}
FRONTEND_URL="http://localhost:${WEB_PORT}"

# DATABASE_URL is constructed using variables from the root .env file
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"