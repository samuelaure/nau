{
  "name": "nau-platform",
  "version": "0.0.0",
  "private": true,
  "description": "naŭ Platform monorepo",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "docker compose -f docker-compose.dev.yml up -d && turbo run dev --parallel",
    "infra:up": "docker compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "build:packages": "pnpm -r --filter './packages/**' build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report"
  },
  "pnpm": {
    "overrides": {
      "multer": "^2.0.0"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "@types/node": "^24.1.0",
    "wait-on": "^8.0.1"
  }
}
