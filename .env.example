# Root-level env vars — used by Playwright E2E tests and monorepo-wide tooling.
# Each app has its own .env.example in apps/<name>/.env.example.
#
# In CI this file's vars are stored as the ROOT_ENV_FILE GitHub secret.
# Locally, copy to .env.production and fill in real values (gitignored).

# --- Gateway (Traefik) ---
# Let's Encrypt ACME certificate notifications.
ACME_EMAIL=

# --- E2E tests (Playwright) ---
# A pre-seeded test account in the accounts/api database.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
