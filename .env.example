# Root-level env vars — used by Playwright E2E tests and monorepo-wide tooling.
# Each app has its own .env.example in apps/<name>/.env.example.

# --- E2E tests (Playwright) ---
# A pre-seeded test account in the accounts/api database.
# Also set as GitHub secrets E2E_USER_EMAIL and E2E_USER_PASSWORD for CI.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
