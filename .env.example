# ─────────────────────────────────────────────────────────────────────────────
# Shared platform environment — loaded by every service in development via:
#   dotenv -e ../../.env.development -e .env.development -- <command>
# App-specific .env files only contain per-app overrides.
# Copy to .env.development for local dev. Never commit real values.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=

# ── Auth (shared HS256 secret — identical across all services) ────────────────
AUTH_SECRET=
COOKIE_DOMAIN=

# ── Service identity ──────────────────────────────────────────────────────────
NAU_SERVICE_KEY=

# ── Internal service URLs ─────────────────────────────────────────────────────
NAU_API_URL=
FLOWNAU_URL=
NAUTHENTICITY_URL=
ZAZU_INTERNAL_URL=

# ── AI ────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Scraping ──────────────────────────────────────────────────────────────────
APIFY_TOKEN=
APIFY_INSTAGRAM_UNIVERSAL_ACTOR_ID=

# ── Storage (Cloudflare R2) ───────────────────────────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Backup (separate private R2 bucket — no public access) ───────────────────
BACKUP_R2_BUCKET_NAME=nau-backups
BACKUP_R2_ACCESS_KEY_ID=
BACKUP_R2_SECRET_ACCESS_KEY=
BACKUP_R2_ENDPOINT=
API_DB_PASSWORD=
FLOWNAU_DB_PASSWORD=
NAUTHENTICITY_DB_PASSWORD=
ZAZU_DB_PASSWORD=
WHATSNAU_DB_PASSWORD=

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# ── Gateway (Traefik / Let's Encrypt) ────────────────────────────────────────
ACME_EMAIL=

# ── E2E tests (Playwright) ────────────────────────────────────────────────────
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
